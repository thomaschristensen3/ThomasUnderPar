generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  password     String?
  isPremium    Boolean   @default(false)
  premiumSince DateTime?
  createdAt    DateTime  @default(now())
}

model Destination {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  country     String
  continent   String   @default("Unknown")
  latitude    Float    @default(0)
  longitude   Float    @default(0)
  heroImage   String
  overallScore Float
  description String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Which categories are active for this destination
  includedCategories Json @default("[\"golf\",\"restaurants\",\"hotels\",\"transportation\",\"weather\",\"city\",\"friendliness\",\"sights\",\"extras\"]")

  // Each category: { score: number, description: string, media: MediaItem[], socialLinks: SocialLink[] }
  golf           Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  restaurants    Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  hotels         Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  transportation Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  weather        Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  city           Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  friendliness   Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  sights         Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
  extras         Json @default("{\"score\":0,\"description\":\"\",\"media\":[],\"socialLinks\":[]}")
}
